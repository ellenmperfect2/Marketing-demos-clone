---
import Page from "../layout/page.astro";
---

<Page>
  
<!-- HERO -->
<section class="hero">
  <div class="hero-gradient"></div>

  <p class="eyebrow">Usage-based monetization platform</p>

  <h1>
    <span class="h1-line1">
      <span class="word-bill">Bill</span>
      <span class="arrow-transform">→</span>
      <span class="word-build">Build</span>
    </span>
    <span class="line2">
      <span class="word-with">with</span> <span class="word-orb">Orb</span>
    </span>
  </h1>

  <p class="hero-sub">
    When revenue data and product data come together, it unlocks new ways to grow. Orb's raw event architecture brings this data directly to your fingertips — so you can build trust with customers, find opportunities to grow, and make your usage data work for you.
  </p>
</section>

<!-- CARDS -->
<section class="cards-section">
  <div class="cards-grid">

    <!-- Card 1: Smart upsells -->
    <a href="/upsell" class="card card-upsells">
      <div class="card-header">
        <div class="card-tag blue">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" fill="#5B72FB"/></svg>
          Smart upsells
        </div>
        <h2>Find the right price for the right user at the right time</h2>
        <p class="card-desc">Surface upsell signals automatically. Build dashboards and workflows that track upsell readiness so your team always knows when to act.</p>
      </div>
      <div class="card-image-wrap">
        <img src="data:image/png;base64," alt="Smart upsells dashboard showing user usage at 90%+ over past 3 months" />
      </div>
      <div class="card-footer">
        <span class="card-cta-text">Build dashboards and workflows that track upsell readiness</span>
        <div class="card-arrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="#130F0B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 7h9M7.5 3l4 4-4 4"/>
          </svg>
        </div>
      </div>
    </a>

    <!-- Card 2: AI Adoption Leaderboards -->
    <a href="/leaderboard" class="card card-leaderboard">
      <div class="card-header">
        <div class="card-tag green">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" fill="#5F8A4D"/></svg>
          AI adoption leaderboards
        </div>
        <h2>Incentivize adoption by gamifying usage</h2>
        <p class="card-desc">Turn your usage data into a competitive leaderboard. The best AI companies drive adoption by making usage visible, social, and rewarding.</p>
      </div>
      <div class="card-image-wrap">
        <img src="data:image/png;base64," alt="AI Adoption Leaderboard showing weekly rankings with awards" />
      </div>
      <div class="card-footer">
        <span class="card-cta-text">Learn how the best AI companies are driving more usage</span>
        <div class="card-arrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="#130F0B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 7h9M7.5 3l4 4-4 4"/>
          </svg>
        </div>
      </div>
    </a>

  </div>
</section>
</Page>


<style>

  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap');

  :root {
    --neutral-darkest: #130F0B;
    --neutral-dark: #5B5448;
    --neutral: #847E74;
    --neutral-light: #E4E1D8;
    --neutral-lightest: #FBF8F0;
    --blue: #5B72FB;
    --blue-dark: #2C2AF8;
    --blue-light: #AAEBFF;
    --blue-lightest: #EFFBFF;
    --green: #5F8A4D;
    --green-light: #BAF289;
    --green-lightest: #F7FBEA;
    --red: #DF4D33;
    --red-light: #FFD8D3;
    --red-lightest: #FFF6F6;
  }


  body {
    background: var(--neutral-lightest);
    color: var(--neutral-darkest);
    font-family: 'DM Sans', Georgia, sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ── NAV ── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 48px;
    border-bottom: 1px solid var(--neutral-light);
    position: sticky;
    top: 0;
    background: rgba(251,248,240,0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .logo {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 22px;
    letter-spacing: -0.5px;
    color: var(--neutral-darkest);
    text-decoration: none;
  }

  .logo span {
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--blue);
    border-radius: 50%;
    margin-left: 3px;
    vertical-align: middle;
    position: relative;
    top: -2px;
  }

  /* ── HERO ── */
  .hero {
    padding: 80px 48px 72px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--neutral);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--neutral);
  }

  h1 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(56px, 7vw, 92px);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  .h1-line1 {
    display: flex;
    align-items: baseline;
    gap: 0.18em;
    flex-wrap: wrap;
  }

  .word-bill {
    color: var(--neutral-light);
    position: relative;
    text-decoration: line-through;
    text-decoration-color: var(--neutral);
  }

  .arrow-transform {
    font-family: 'DM Mono', monospace;
    font-size: 0.45em;
    color: var(--neutral);
    font-weight: 400;
    letter-spacing: 0;
    position: relative;
    top: -0.1em;
  }

  .word-build {
    color: var(--neutral-darkest);
  }

  h1 .line2 {
    display: block;
    color: var(--neutral-darkest);
  }

  .word-with {
    color: var(--neutral-dark);
    font-style: italic;
  }

  .word-orb {
    color: var(--blue-dark);
  }

  /* accent underline on Orb */
  .word-orb {
    position: relative;
  }
  .word-orb::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue) 0%, var(--blue-light) 100%);
    border-radius: 2px;
  }

  .hero-sub {
    max-width: 600px;
    margin-top: 36px;
    font-size: 17px;
    line-height: 1.65;
    color: var(--neutral-dark);
    font-weight: 300;
  }

  /* ── AMBIENT GRADIENT BACKGROUND ── */
  .hero-gradient {
    position: absolute;
    top: -40px;
    right: -80px;
    width: 600px;
    height: 500px;
    background: radial-gradient(ellipse at 70% 40%, rgba(170,235,255,0.35) 0%, rgba(91,114,251,0.12) 40%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero > * { position: relative; z-index: 1; }

  /* ── CARDS SECTION ── */
  .cards-section {
    padding: 0 48px 96px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .card {
    border-radius: 16px;
    border: 1px solid var(--neutral-light);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: #fff;
    transition: box-shadow 0.25s, transform 0.25s;
    cursor: pointer;
    position: relative;
    text-decoration: none;
  }

  .card:hover {
    box-shadow: 0 12px 40px rgba(19,15,11,0.1);
    transform: translateY(-2px);
  }

  .card-header {
    padding: 32px 32px 0;
  }

  .card-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .card-tag.blue {
    background: var(--blue-lightest);
    color: var(--blue-dark);
    border: 1px solid var(--blue-light);
  }

  .card-tag.green {
    background: var(--green-lightest);
    color: var(--green);
    border: 1px solid #BAF289;
  }

  .card h2 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 28px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--neutral-darkest);
    margin-bottom: 12px;
  }

  .card-desc {
    font-size: 15px;
    line-height: 1.55;
    color: var(--neutral-dark);
    font-weight: 300;
    margin-bottom: 24px;
  }

  /* ── CARD IMAGES ── */
  .card-image-wrap {
    flex: 1;
    overflow: hidden;
    border-top: 1px solid var(--neutral-light);
    margin: 0;
    background: var(--neutral-lightest);
    display: flex;
    align-items: flex-start;
    min-height: 260px;
    position: relative;
  }

  .card-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top center;
  }

  /* gradient fade at bottom of image */
  .card-image-wrap::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.9));
    pointer-events: none;
  }

  .card-footer {
    padding: 20px 32px 28px;
    border-top: 1px solid var(--neutral-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-cta-text {
    font-size: 13px;
    line-height: 1.45;
    color: var(--neutral-dark);
    max-width: 280px;
  }

  .card-arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--neutral-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }

  .card:hover .card-arrow {
    background: var(--neutral-darkest);
    border-color: var(--neutral-darkest);
  }

  .card:hover .card-arrow svg { stroke: var(--neutral-lightest); }

  /* card 1 accent gradient */
  .card.card-upsells {
    background: linear-gradient(160deg, #fff 60%, var(--blue-lightest) 100%);
  }

  /* card 2 accent gradient */
  .card.card-leaderboard {
    background: linear-gradient(160deg, #fff 60%, var(--green-lightest) 100%);
  }

  /* ── BOTTOM STRIP ── */
  .bottom-strip {
    background: var(--neutral-darkest);
    padding: 40px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bottom-strip p {
    font-size: 14px;
    color: var(--neutral);
  }

  .bottom-strip a {
    font-size: 14px;
    color: var(--blue-light);
    text-decoration: none;
    font-weight: 500;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero > * {
    animation: fadeUp 0.6s ease both;
  }

  .eyebrow { animation-delay: 0s; }
  h1       { animation-delay: 0.08s; }
  .hero-sub { animation-delay: 0.16s; }

  .cards-grid .card:nth-child(1) {
    animation: fadeUp 0.55s 0.22s ease both;
  }
  .cards-grid .card:nth-child(2) {
    animation: fadeUp 0.55s 0.32s ease both;
  }

</style>
